generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MEMBER
  MODERATOR
  ADMIN
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum VerificationCodePurpose {
  LOGIN
  REGISTER
  RESET_PASSWORD
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String?         @unique
  passwordHash   String?         @db.VarChar(255)
  emailVerified  DateTime?
  image          String?
  username       String?         @unique
  headline       String?
  bio            String?         @db.Text
  role           UserRole        @default(MEMBER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  sessions       Session[]
  authenticators Authenticator[]
  posts          Post[]
  comments       Comment[]
  postLikes      PostLike[]
  postFavorites  PostFavorite[]
  postViews      PostView[]

  @@index([createdAt])
}

model Post {
  id          String         @id @default(cuid())
  title       String         @db.VarChar(160)
  slug        String         @unique @db.VarChar(180)
  excerpt     String?        @db.VarChar(280)
  content     String         @db.Text
  status      PostStatus     @default(PUBLISHED)
  authorId    String
  viewCount   Int            @default(0)
  publishedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  author      User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  attachments PostAttachment[]
  comments    Comment[]
  tags        Tag[]
  likes       PostLike[]
  favorites   PostFavorite[]
  views       PostView[]

  @@index([authorId, createdAt])
  @@index([status, publishedAt])
}

model PostAttachment {
  id           String   @id @default(cuid())
  postId       String
  originalName String   @db.VarChar(255)
  mimeType     String   @db.VarChar(120)
  storagePath  String   @unique @db.VarChar(255)
  size         Int
  createdAt    DateTime @default(now())
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

model PostLike {
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId, createdAt])
}

model PostFavorite {
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId, createdAt])
}

model PostView {
  postId       String
  viewerKey    String   @db.VarChar(96)
  userId       String?
  createdAt    DateTime @default(now())
  lastViewedAt DateTime @default(now())
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, viewerKey])
  @@index([userId, lastViewedAt])
  @@index([lastViewedAt])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  authorId  String
  postId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([authorId, createdAt])
}

model Tag {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(40)
  slug        String   @unique @db.VarChar(48)
  description String?  @db.VarChar(160)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       Post[]
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expires])
}

model EmailVerificationCode {
  id                     String                  @id @default(cuid())
  email                  String                  @db.VarChar(320)
  codeHash               String                  @db.VarChar(128)
  purpose                VerificationCodePurpose @default(LOGIN)
  expiresAt              DateTime
  consumedAt             DateTime?
  invalidatedAt          DateTime?
  verifiedTokenHash      String?                 @db.VarChar(128)
  verifiedTokenExpiresAt DateTime?
  attemptCount           Int                     @default(0)
  sendIp                 String?                 @db.VarChar(64)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([email, createdAt])
  @@index([email, expiresAt])
  @@index([email, consumedAt, invalidatedAt])
  @@index([email, purpose, verifiedTokenExpiresAt])
  @@index([verifiedTokenHash])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Authenticator {
  credentialID         String  @id
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, credentialID])
}
